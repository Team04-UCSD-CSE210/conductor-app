{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["docs/scripts/prettify/**/*.js"],
      "env": { "browser": true },
      "globals": { "PR": "readonly" },
      "rules": {
        "no-undef": "off",
        "no-redeclare": "off",
        "no-cond-assign": "off",
        "no-prototype-builtins": "off",
        "no-useless-escape": "off"
      }
    },
    {
      "files": ["tests/**/*.js", "**/*.spec.js"],
      "env": { "node": true },
      "globals": {
        "vi": "readonly",
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly"
      }
    },
    {
      "files": ["apps/web/**/*.js"],
      "env": { "browser": true }
    }
  ]
}
